# Copy to deploy/compose/.env (optional). Loaded by docker-compose.yml.
# Does not start containers by itself.

# Logging for node/client processes inside containers
AEGIS_RUST_LOG=info

# Host port publishes (container still listens on 17419–17422)
AEGIS_NODE0_HOST_PORT=17419
AEGIS_NODE1_HOST_PORT=17420
AEGIS_NODE2_HOST_PORT=17421
AEGIS_NODE3_HOST_PORT=17422

# Client profile (docker compose --profile client run --rm client)
AEGIS_CLIENT_PAYLOAD=docker-pilot
AEGIS_COVER_SECS=2
AEGIS_TAU_SECS=0.35

# Compose project name override (optional)
# COMPOSE_PROJECT_NAME=aegis-pilot
